{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rannday.github.io/blockforge-manifest/manifest.schema.json",
  "title": "Blockforge Server Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "schema_version",
    "minecraft",
    "loader",
    "server_config",
    "mods"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Blockforge manifest schema version. Consumers use this to decide whether they understand the manifest format."
    },
    "pack": {
      "type": "string",
      "minLength": 1,
      "description": "Optional modpack identifier. This is metadata only; the schema does not reserve or enforce specific pack names."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "minecraft": {
      "type": "string",
      "minLength": 1
    },
    "server_config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "sha1"
      ],
      "properties": {
        "url": {
          "$ref": "#/$defs/httpZipUrl"
        },
        "sha1": {
          "$ref": "#/$defs/sha1"
        }
      }
    },
    "loader": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "version",
        "installer_url",
        "sha1"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "neoforge",
            "forge",
            "fabric",
            "quilt"
          ],
          "description": "Minecraft mod loader used by this server manifest."
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "installer_url": {
          "$ref": "#/$defs/httpJarUrl"
        },
        "sha1": {
          "$ref": "#/$defs/sha1"
        }
      }
    },
    "mods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "url",
          "website_url",
          "sha1",
          "size"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "$ref": "#/$defs/httpJarUrl"
          },
          "website_url": {
            "$ref": "#/$defs/httpUrl"
          },
          "sha1": {
            "$ref": "#/$defs/sha1"
          },
          "size": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  },
  "$defs": {
    "sha1": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "httpUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://"
    },
    "httpJarUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://.*\\.[jJ][aA][rR](?:[?#].*)?$"
    },
    "httpZipUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://.*\\.[zZ][iI][pP](?:[?#].*)?$"
    }
  }
}

